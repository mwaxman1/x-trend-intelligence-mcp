{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "src/api/mcp.ts": { "memory": "512mb" },
    "src/api/health.ts": { "memory": "128mb" }
  },
  "routes": [
    { "src": "/api/mcp", "dest": "/api/mcp" },
    { "src": "/api/health", "dest": "/api/health" }
  ]
}