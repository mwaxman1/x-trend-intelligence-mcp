{
  "version": 2,
  "buildCommand": "npm run build && cp public/index.html dist/index.html",
  "outputDirectory": "dist",
  "functions": {
    "api/mcp.ts": { "memory": 512 },
    "api/health.ts": { "memory": 128 }
  },
  "routes": [
    { "src": "/api/mcp", "dest": "/api/mcp" },
    { "src": "/api/health", "dest": "/api/health" }
  ]
}